# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Virtual environments
venv/
env/
.venv/
ENV/
.env.bak

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
*.xml

# Jupyter
.ipynb_checkpoints/

# ── Environment & Secrets ─────────────────────────────────────────────────────
# Keep .env.example but NEVER commit the real .env
backend/.env
.env
*.env

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vite build output
frontend/dist/
frontend/.vite/

# ── ChromaDB (vector database — persisted locally, regenerate on deploy) ──────
backend/chroma_db/

# ── Model cache (HuggingFace / sentence-transformers — downloaded at runtime) ─
backend/.cache/

# ── Uploaded documents ────────────────────────────────────────────────────────
# Keep the folder but ignore any actual files uploaded at runtime
backend/uploads/*
!backend/uploads/.gitkeep

# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
