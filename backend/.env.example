# ── Gemini API ──────────────────────────────────────────────────────────────
# Required: your Google AI Studio API key
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use. The backend will validate this at startup and automatically
# fall back in this order if unavailable:
#   gemini-2.5-flash → gemini-2.5-flash-lite → gemini-1.5-flash
MODEL_NAME=gemini-2.5-flash

# ── RAG Settings ─────────────────────────────────────────────────────────────
# Number of chunks retrieved per query
TOP_K=5

# Document chunking
CHUNK_SIZE=700
CHUNK_OVERLAP=150
