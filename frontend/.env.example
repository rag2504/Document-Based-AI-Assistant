# ── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local for local development (never commit .env.local)

# URL of your deployed backend (Render service URL)
# In Vercel Dashboard → Project Settings → Environment Variables, set:
#   VITE_API_URL = https://your-render-service.onrender.com
#
# For local development, leave this blank — the app defaults to http://localhost:8000
VITE_API_URL=
